# Copy to .env and fill from Supabase: Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Never put the service_role / secret key in Vite env vars (it would ship to the browser).

# --- Cloudflare / CI ---
# These values are read when `npm run build` runs (they are embedded in the static JS).
# Worker "Variables and secrets" alone are usually NOT available at build time.
# • Cloudflare Pages: Settings → Environment variables → add for Production/Preview *build*.
# • Optional aliases (same values): SUPABASE_URL, SUPABASE_ANON_KEY (see vite.config.ts).
